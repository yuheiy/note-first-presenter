{
  "name": "@note-first-presenter/client",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "src",
    "!src/**/__tests__",
    "messages",
    "project.inlang",
    "svelte.config.js",
    "tsconfig.json"
  ],
  "type": "module",
  "imports": {
    "#lib/*": [
      "./src/lib/*",
      "./src/lib/*.ts",
      "./src/lib/*.js"
    ]
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vp test",
    "check": "vp check && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "bowser": "catalog:",
    "esm-env": "catalog:",
    "ofetch": "catalog:",
    "prosemirror-commands": "catalog:",
    "prosemirror-history": "catalog:",
    "prosemirror-keymap": "catalog:",
    "prosemirror-model": "catalog:",
    "prosemirror-schema-list": "catalog:",
    "prosemirror-state": "catalog:",
    "prosemirror-transform": "catalog:",
    "prosemirror-view": "catalog:",
    "svelte": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest-browser-svelte": "catalog:"
  }
}
